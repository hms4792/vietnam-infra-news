          "name": "옌짜 (Yen Xa)",
          "location": "하노이 (Thanh Tri)",
          "capacity": "270,000 m³/일",
          "note": "2025.8.19 준공, 북부 최대"
        },
        {
          "name": "빈흥 (Binh Hung)",
          "location": "호치민 (Binh Chanh)",
