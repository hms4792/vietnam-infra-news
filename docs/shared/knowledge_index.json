    "VN-WW-2030": {
      "title_ko": "폐수처리 인프라 국가 마스터플랜 2021~2030",
      "decision": "Decision 1354/QD-TTg",
      "description_ko": "국가 폐수처리 마스터플랜(2021~2030)은 도시 폐수처리율을 2025년 50%, 2030년 85%로 끌어올리는 것을 목표로 한다. 하노이·호치민·다낭 등 주요 도시 권역별 WWTP 신규·확장이 핵심이며, JICA·ADB·KfW 등 다자금융기관 ODA가 투자의 80% 이상을 차지한다.",
      "kpi_targets": [
        {
          "indicator": "도시 폐수처리율",
          "target_2030": "85%",
          "current": "~29% → 50% (하노이 옌짜 준공)"
        },
        {
          "indicator": "신규 WWTP 용량",
          "target_2030": "2,900,000 m³/일",
          "current": "약 800,000 m³/일 운영"
        },
        {
          "indicator": "ODA 연계 투자",
          "target_2030": "$2.5B+",
          "current": "JICA $690M (옌짜 준공 확정)"
        }
      ],
      "key_projects": [
